# Server
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# Database (PostgreSQL)
DATABASE_URL="postgresql://orbicorp:orbicorp_secret_2026@localhost:5432/orbicorp?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="your-refresh-secret-key-also-change-this-in-production"
JWT_REFRESH_EXPIRES_IN="7d"

# CORS
CORS_ORIGIN="http://localhost:3000,http://localhost:8000"

# LLM API Keys (opsiyonel - sonra eklenecek)
# ANTHROPIC_API_KEY=""
# OPENAI_API_KEY=""
# GOOGLE_API_KEY=""
# OPENROUTER_API_KEY=""   # Tek key ile tüm modellere erişim!

# Logging
LOG_LEVEL="info"
